name: kumavpn-{{ tenant.name }}

services:
  openvpn:
    image: kumavpn/openvpn:latest
    container_name: openvpn-{{ tenant.name }}
    restart: unless-stopped
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    sysctls:
      - net.ipv4.ip_forward=1
    environment:
      IP_VPN: "{{ tenant.vpn_subnet }}"
      MASCARA_VPN: "{{ tenant.vpn_mask }}"
      VPN_PORT: "{{ tenant.vpn_port }}"
      VPN_PROTO: "tcp"
      WG_PORT: "{{ tenant.wg_port }}"
      WG_SUBNET: "{{ tenant.wg_subnet }}"
    ports:
      - "{{ tenant.vpn_port }}:{{ tenant.vpn_port }}/tcp"
      - "{{ tenant.wg_port }}:{{ tenant.wg_port }}/udp"
      - "{{ kuma_bind | default('0.0.0.0') }}:{{ tenant.kuma_port }}:3001"
    volumes:
      - {{ base_path }}/tenants/{{ tenant.name }}/openvpn:/etc/openvpn

  kuma:
    image: louislam/uptime-kuma:1
    container_name: kuma-{{ tenant.name }}
    restart: unless-stopped
    network_mode: "service:openvpn"
    volumes:
      - {{ base_path }}/tenants/{{ tenant.name }}/kuma:/app/data
    depends_on:
      - openvpn
