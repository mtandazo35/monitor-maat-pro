# --- Web admin ---
ADMIN_USER=admin

# Bcrypt hash de la contraseña de admin. Generarlo con:
#   docker run --rm python:3.12-slim python -c "import bcrypt; print(bcrypt.hashpw(b'TU_CLAVE', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Secret para cookies de sesión (mínimo 32 caracteres aleatorios)
#   openssl rand -hex 32
SESSION_SECRET=

# Puerto del panel en el host
ADMIN_PORT=8000
# Interfaz donde se publica el panel. Default 0.0.0.0 (todas). Detrás de un reverse
# proxy (NPM/Caddy) en el MISMO host, poner 127.0.0.1 para no exponer :8000 a internet.
ADMIN_BIND=0.0.0.0
# Cookie de sesión Secure. Poner 1 cuando el panel se sirve por HTTPS (proxy con TLS).
SECURE_COOKIES=0

# --- VPN / Kuma ---
# IP pública fija del servidor (si la dejás vacía intenta detectarla al crear tenant)
PUBLIC_IP=

# Puerto OpenVPN base. Tenant N usa VPN_PORT_BASE + N (slot 1 => 1194)
VPN_PORT_BASE=1193

# Puerto Kuma base. Tenant N usa KUMA_PORT_BASE + N
KUMA_PORT_BASE=3000
# Interfaz donde se publica el Kuma de cada tenant. Default 0.0.0.0 (todas). Con un
# proxy local, poner 127.0.0.1: cierra a internet el wizard de setup sin-auth de Kuma.
KUMA_BIND=0.0.0.0

# Rango VPN por tenant: 100.64.<slot>.0/24
VPN_SUBNET_PREFIX=100.64

# Rango red Docker interna por tenant: 172.30.<slot>.0/24
DOCKER_SUBNET_PREFIX=172.30

# --- SMTP (opcional, para mandar credenciales por email a usuarios nuevos) ---
# Si SMTP_HOST queda vacío, las passwords se muestran en el flash al admin.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=kumavpn@tudominio.com
# STARTTLS (puerto 587). Para SSL implícito (465), poner SMTP_SSL=true y SMTP_TLS=false
SMTP_TLS=true
SMTP_SSL=false

# URL pública del panel (incluida en los emails). Vacío → http://PUBLIC_IP:ADMIN_PORT
PUBLIC_URL=
